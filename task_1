stock_prices = {
    "AAPL": 180,
    "TSLA": 250,
    "GOOG": 150,
    "MSFT": 320,
    "AMZN": 140
}

total_value = 0

print("===== STOCK PORTFOLIO TRACKER =====")

while True:
   
    stock = input("Enter Stock Name (AAPL/TSLA/GOOG/MSFT/AMZN): ").upper()

    # Check if stock exists
    if stock in stock_prices:
        quantity = int(input("Enter Quantity: "))

        # Calculate stock value
        value = stock_prices[stock] * quantity
        total_value += value

        print("Value of", stock, "=", value)
    else:
        print("Stock not available!")

    # Ask user whether to continue
    choice = input("Do you want to add another stock? (yes/no): ").lower()

    if choice != "yes":
        break

# Display total investment
print("\n===== INVESTMENT SUMMARY =====")
print("Total Investment Value = $", total_value)

# Save result to a text file
file = open("portfolio.txt", "w")
file.write("Total Investment Value = $" + str(total_value))
file.close()

print("Portfolio details saved successfully in portfolio.txt")
